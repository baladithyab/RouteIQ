    "ObservabilityConstructRoutingLatencyAlarm28D0B59A": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "ObservabilityConstructAlarmTopic6B087DCD"
          }
        ],
        "AlarmDescription": "RouteIQ dev routing latency exceeded 30000 ms (30s absolute ceiling) for 3 consecutive minutes - a wedged routing path, a large-prompt timeout, or a backend stall. Reads the aggregate routing_latency_ms CW Logs metric filter.",
        "AlarmName": "routeiq-dev-routing-latency-high",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 3,
        "EvaluationPeriods": 3,
        "MetricName": "routing_latency_ms",
        "Namespace": "routeiq/dev/router",
        "OKActions": [
          {
            "Ref": "ObservabilityConstructAlarmTopic6B087DCD"
          }
        ],
        "Period": 60,
        "Statistic": "Maximum",
        "Tags": [
          {
            "Key": "routeiq:env",
            "Value": "dev"
          }
        ],
        "Threshold": 30000,
        "TreatMissingData": "notBreaching"
      },
      "Type": "AWS::CloudWatch::Alarm"
    },
    "ObservabilityConstructRoutingLatencyAnomalyAlarm8BEAF313": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "ObservabilityConstructAlarmTopic6B087DCD"
          }
        ],
        "AlarmDescription": "RouteIQ dev routing latency is abnormally HIGH vs its self-trained 3-sigma band (anomaly detection on average routing_latency_ms over 5min). Reads INSUFFICIENT_DATA until the band trains on ~2 weeks of traffic.",
        "AlarmName": "routeiq-dev-routing-latency-anomaly",
        "ComparisonOperator": "GreaterThanUpperThreshold",
        "EvaluationPeriods": 3,
        "Metrics": [
          {
            "Expression": "ANOMALY_DETECTION_BAND(m0, 3)",
            "Id": "expr_1",
            "Label": "Anomaly Detection Band",
            "ReturnData": true
          },
          {
            "Id": "m0",
            "MetricStat": {
              "Metric": {
                "MetricName": "routing_latency_ms",
                "Namespace": "routeiq/dev/router"
              },
              "Period": 300,
              "Stat": "Average"
            },
            "ReturnData": true
          }
        ],
        "OKActions": [
          {
            "Ref": "ObservabilityConstructAlarmTopic6B087DCD"
          }
        ],
        "Tags": [
          {
            "Key": "routeiq:env",
            "Value": "dev"
          }
        ],
        "ThresholdMetricId": "expr_1",
        "TreatMissingData": "notBreaching"
      },
      "Type": "AWS::CloudWatch::Alarm"
    },
