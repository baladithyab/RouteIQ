# =============================================================================
# RouteIQ Gateway - Full Stack Environment Variables (HA + Observability)
# =============================================================================
# Copy this file to .env and customize values before starting:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Master API key for admin access to the gateway.
# IMPORTANT: Change this in production! Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-test-master-key-change-me

# -----------------------------------------------------------------------------
# LLM Provider - OpenRouter
# -----------------------------------------------------------------------------
# OpenRouter provides access to 100+ LLM models through a single API key.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# Persistent storage for API keys, spend tracking, and team management.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm_password
POSTGRES_DB=litellm

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
# Used for response caching, rate limiting, and distributed state.
REDIS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# HA Settings
# -----------------------------------------------------------------------------
# Leader election mode for config sync (only leader syncs config)
LLMROUTER_HA_MODE=leader_election
LLMROUTER_CONFIG_SYNC_LEASE_SECONDS=30
LLMROUTER_CONFIG_SYNC_RENEW_INTERVAL_SECONDS=10

# Store models in database for cross-replica consistency
STORE_MODEL_IN_DB=true

# Config hot reload and sync
CONFIG_HOT_RELOAD=true
CONFIG_SYNC_ENABLED=true
CONFIG_SYNC_INTERVAL=60

# -----------------------------------------------------------------------------
# OpenTelemetry Settings
# -----------------------------------------------------------------------------
# Traces are exported to Jaeger via OTLP gRPC (configured in docker-compose.yml).
# Override these to point to a different collector (e.g., AWS ADOT).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=litellm-gateway

# -----------------------------------------------------------------------------
# Gateway Features
# -----------------------------------------------------------------------------
# A2A (Agent-to-Agent) and MCP (Model Context Protocol) gateways
A2A_GATEWAY_ENABLED=true
MCP_GATEWAY_ENABLED=true

# Admin UI at /ui/
ROUTEIQ_ADMIN_UI_ENABLED=true

# -----------------------------------------------------------------------------
# RouteIQ Routing Settings
# -----------------------------------------------------------------------------
# Use plugin-based routing strategy (supports multi-worker)
ROUTEIQ_USE_PLUGIN_STRATEGY=true

# Enable centroid-based intelligent routing (~2ms prompt classification)
ROUTEIQ_CENTROID_ROUTING=true

# Routing profile: auto | eco | premium | free | reasoning
ROUTEIQ_ROUTING_PROFILE=auto
