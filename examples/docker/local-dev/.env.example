# =============================================================================
# RouteIQ Gateway - Local Development Environment Variables
# =============================================================================
# Copy this file to .env and customize values before starting:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Master API key for admin access to the gateway.
LITELLM_MASTER_KEY=sk-test-master-key-change-me

# Admin API key for control-plane operations (MCP, A2A, hot-reload)
ADMIN_API_KEY=local-dev-admin-key

# -----------------------------------------------------------------------------
# LLM Provider - OpenRouter
# -----------------------------------------------------------------------------
# OpenRouter provides access to 100+ LLM models through a single API key.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# -----------------------------------------------------------------------------
# AWS Credentials (Optional - for Bedrock models)
# -----------------------------------------------------------------------------
# If using AWS Bedrock models, set these before starting.
# Export from AWS CLI: eval $(aws configure export-credentials --format env)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-west-2

# -----------------------------------------------------------------------------
# RouteIQ Routing Settings
# -----------------------------------------------------------------------------
# Use plugin-based routing strategy (supports multi-worker)
ROUTEIQ_USE_PLUGIN_STRATEGY=true

# Enable centroid-based intelligent routing (~2ms prompt classification)
ROUTEIQ_CENTROID_ROUTING=true

# Routing profile: auto | eco | premium | free | reasoning
ROUTEIQ_ROUTING_PROFILE=auto

# Enable admin UI at /ui/
ROUTEIQ_ADMIN_UI_ENABLED=true
