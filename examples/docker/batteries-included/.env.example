# =============================================================================
# RouteIQ Gateway — Batteries-Included Environment Variables
# =============================================================================
# All services (Postgres, Redis, OTel, Jaeger) are bundled in the compose file.
# You only need to set your API keys and master key here.
#
# Copy this file to .env: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Master API key for admin access. Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=changeme-generate-a-real-key

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------
# Uncomment and set the keys for your providers:

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (100+ models via single key): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# Bundled Service Passwords (change for security)
# -----------------------------------------------------------------------------
# These are used by the bundled PostgreSQL and Redis containers.
# In production, use the plug-in example with managed services instead.
POSTGRES_USER=routeiq
POSTGRES_PASSWORD=routeiq_local
POSTGRES_DB=litellm
REDIS_PASSWORD=routeiq_local
