# RouteIQ Slim - Environment Configuration
# Copy this file to .env and fill in your values

# SECURITY: Set a real master key in production
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-routeiq-dev-key

# LLM Provider API Keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Routing profile: auto | eco | premium | free | reasoning
ROUTEIQ_ROUTING_PROFILE=auto

# Workers (1 is fine for slim deployments)
ROUTEIQ_WORKERS=1

# Admin API keys (comma-separated, for control plane)
ADMIN_API_KEYS=

# OpenTelemetry (uncomment to enable)
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=routeiq-slim
