# =============================================================================
# RouteIQ Gateway — Plug-In Mode Environment Variables
# =============================================================================
# Configure RouteIQ to connect to your existing managed services.
# Copy this file to .env and fill in the values for your infrastructure.
#
# RouteIQ degrades gracefully: any service left unconfigured simply
# disables the corresponding feature. Check /config/services at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Master API key for admin access. Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=changeme-generate-a-real-key

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------
# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (100+ models via single key): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# PostgreSQL — Enables: persistence, DB-backed API keys, team management
# -----------------------------------------------------------------------------
# Leave blank to run without persistence (in-memory only).
#
# AWS RDS example:
#   DATABASE_URL=postgresql://routeiq:password@mydb.abc123.us-east-1.rds.amazonaws.com:5432/litellm
#
# GCP Cloud SQL example:
#   DATABASE_URL=postgresql://routeiq:password@/litellm?host=/cloudsql/project:region:instance
#
# Azure Database for PostgreSQL:
#   DATABASE_URL=postgresql://routeiq@myserver:password@myserver.postgres.database.azure.com:5432/litellm?sslmode=require
#
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis — Enables: response caching, HA leader election, rate limiting
# -----------------------------------------------------------------------------
# Leave blank to run without caching/HA.
#
# AWS ElastiCache example:
#   REDIS_HOST=my-cluster.abc123.0001.use1.cache.amazonaws.com
#   REDIS_PORT=6379
#   REDIS_PASSWORD=your-auth-token
#   REDIS_SSL=true
#
# GCP Memorystore example:
#   REDIS_HOST=10.0.0.3
#   REDIS_PORT=6379
#
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# -----------------------------------------------------------------------------
# OpenTelemetry — Enables: distributed tracing, metrics export
# -----------------------------------------------------------------------------
# Leave blank to disable observability export.
#
# Self-hosted collector:
#   OTEL_ENDPOINT=http://otel-collector:4317
#
# Datadog:
#   OTEL_ENDPOINT=http://datadog-agent:4317
#
# Grafana Cloud (via Alloy):
#   OTEL_ENDPOINT=http://grafana-alloy:4317
#
# AWS X-Ray (via ADOT collector):
#   OTEL_ENDPOINT=http://adot-collector:4317
#
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=routeiq-gateway
OTEL_ENABLED=true

# -----------------------------------------------------------------------------
# OIDC / SSO — Enables: single sign-on for admin UI
# -----------------------------------------------------------------------------
# Leave disabled for API-key-only authentication.
#
# Auth0 example:
#   OIDC_ENABLED=true
#   OIDC_ISSUER_URL=https://your-tenant.auth0.com/
#   OIDC_CLIENT_ID=your-client-id
#   OIDC_CLIENT_SECRET=your-client-secret
#
# Okta example:
#   OIDC_ENABLED=true
#   OIDC_ISSUER_URL=https://your-org.okta.com/oauth2/default
#
# Google Workspace:
#   OIDC_ENABLED=true
#   OIDC_ISSUER_URL=https://accounts.google.com
#
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# RouteIQ Settings
# -----------------------------------------------------------------------------
# Number of uvicorn workers per container
ROUTEIQ_WORKERS=2

# Routing profile: auto | eco | premium | free | reasoning
ROUTEIQ_ROUTING_PROFILE=auto

# Enable admin dashboard at /ui/
ROUTEIQ_ADMIN_UI_ENABLED=true

# Gateway features
A2A_GATEWAY_ENABLED=false
MCP_GATEWAY_ENABLED=false
